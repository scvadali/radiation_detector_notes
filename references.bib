@article{aglieri_rinella_charge_2021,
	title = {Charge collection properties of {TowerJazz} 180 nm {CMOS} {Pixel} {Sensors} in dependence of pixel geometries and bias parameters, studied using a dedicated test-vehicle: {The} {Investigator} chip},
	volume = {988},
	issn = {01689002},
	shorttitle = {Charge collection properties of {TowerJazz} 180 nm {CMOS} {Pixel} {Sensors} in dependence of pixel geometries and bias parameters, studied using a dedicated test-vehicle},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0168900220312560},
	doi = {10.1016/j.nima.2020.164859},
	abstract = {This paper contains a compilation of parameters influencing the charge collection process extracted from a comprehensive study of partially depleted Monolithic Active Pixel Sensors with small ({\textless}25 μm2) collection electrodes fabricated in the TowerJazz 180 nm CMOS process. These results gave guidance for the optimization of the diode implemented in ALPIDE, the chip used in the second generation Inner Tracking System of ALICE, and serve as reference for future simulation studies of similar devices. The studied parameters include: reverse substrate bias, epitaxial layer thickness, charge collection electrode size and the spacing of the electrode to surrounding in-pixel electronics. The results from pixels of 28 μm pitch confirm that even in partially depleted circuits, charge collection can be fast ({\textless}10 ns), and quantify the influence of the parameters onto the signal sharing and amplitudes, highlighting the importance of a correct spacing between wells and of the impact of the reverse substrate bias.},
	language = {en},
	urldate = {2026-06-22},
	journal = {Nuclear Instruments and Methods in Physics Research Section A: Accelerators, Spectrometers, Detectors and Associated Equipment},
	author = {Aglieri Rinella, G. and Chaosong, G. and Di Mauro, A. and Eum, J. and Hillemanns, H. and Junique, A. and Keil, M. and Kim, D. and Kim, H. and Kugathasan, T. and Lee, S. and Mager, M. and Manzari, V. and Marin Tobon, C.A. and Martinengo, P. and Mugnier, H. and Musa, L. and Reidt, F. and Rousset, J. and Sielewicz, K. and Snoeys, W. and Šuljić, M. and Van Hoorne, J.W. and Malik, Q.W. and Yang, P. and Yoo, I.-K.},
	month = feb,
	year = {2021},
	keywords = {MAPS},
	pages = {164859},
	file = {PDF:C\:\\Users\\Chandrahaas Vadali\\Zotero\\storage\\JP3REFQX\\Aglieri Rinella et al. - 2021 - Charge collection properties of TowerJazz 180 nm CMOS Pixel Sensors in dependence of pixel geometrie.pdf:application/pdf},
}




@article{coath_low_2010,
	title = {A {Low} {Noise} {Pixel} {Architecture} for {Scientific} {CMOS} {Monolithic} {Active} {Pixel} {Sensors}},
	volume = {57},
	issn = {1558-1578},
	url = {https://ieeexplore.ieee.org/document/5512562/},
	doi = {10.1109/TNS.2010.2052469},
	abstract = {This paper presents the design and characterisation of FORTIS (4T Test Image Sensor), which is a low noise, CMOS monolithic active pixel sensor for scientific applications. The pixels present in FORTIS are based around the four transistor (4T) pixel architecture, which is already widely used in the commercial imaging community. The sensor design contains thirteen different variants of the 4T pixel architecture to investigate the effects of changing its core parameters. The variants include differences in the pixel pitch, the diode size, the in-pixel source follower, and the capacitance of the floating diffusion node (the input node of the in-pixel source follower). Processing variations have also been studied, which include varying the resistivity of the epitaxial layer and investigating the effects of a special deep p-well layer. By varying these parameters, the 4T pixel architecture can be optimised for scientific applications where detection of small amounts of charge is required.},
	number = {5},
	urldate = {2026-06-23},
	journal = {IEEE Transactions on Nuclear Science},
	author = {Coath, Rebecca E. and Crooks, Jamie P. and Godbeer, Adam and Wilson, Matthew D. and Zhang, Zhige and Stanitzki, Marcel and Tyndel, Mike and Turchetta, Renato A. D.},
	month = oct,
	year = {2010},
	keywords = {4T pixel, Active noise reduction, active pixel sensors, Capacitance, CMOS image sensors, Conductivity, Diodes, Epitaxial layers, high resistivity epitaxial layer, image sensors, Image sensors, low noise image sensor, pinned photodiode, Pixel, radiation hardness, random telegraph signal noise, Sensor phenomena and characterization, Testing},
	pages = {2490--2496},
	annote = {4T},
	file = {Full Text PDF:C\:\\Users\\Chandrahaas Vadali\\Zotero\\storage\\WRRS5IRN\\Coath et al. - 2010 - A Low Noise Pixel Architecture for Scientific CMOS Monolithic Active Pixel Sensors.pdf:application/pdf},
}


